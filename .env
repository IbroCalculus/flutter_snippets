
NB: This is for flutter, using flutter_dotenv. There is dotenv for dart projects. CHECK .env in dart.

dependencies:
  flutter_dotenv: ^6.0.1


---------- main.dart ------------
import 'package:flutter_dotenv/flutter_dotenv.dart';

Future<void> main() async {
  await dotenv.load();
  runApp(const MyApp());
}


---------- home_page.dart ---------------

class _HomePageState extends State<HomePage> {

  final exchange_rate_api_key = dotenv.get('EXCHANGE_RATE_API_KEY');

  @override
  Widget build(BuildContext context) {
    
    print('Exchange Rate API Key: ${exchange_rate_api_key}');
    return Scaffold(
      body: SafeArea(child: Placeholder()),
    );
  }
}